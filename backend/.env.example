# ─────────────────────────────────────────────────────────────────────────────
# DeepScan Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Flask environment: development | production | testing
FLASK_ENV=development

# Server port (must match REACT_APP_API_BASE_URL in the React .env)
PORT=8000

# Secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_FOLDER=./uploads

# ── AI Model weight files ─────────────────────────────────────────────────────
# Place your trained model files here, then set the paths below.
# The backend runs in DEMO mode (random weights) if these files are not found.

MODELS_DIR=./models/weights

# Image model: EfficientNet-B4 trained on CIFAKE / 140k dataset
IMAGE_MODEL_PATH=./models/weights/best_image_model.keras

# Image fusion model artifacts (EfficientNet + Dlib + SVM)
IMAGE_FUSION_SVM_PATH=./models/weights/svm_efficientnet_b4.pkl
IMAGE_FUSION_PCA_PATH=./models/weights/pca_efficientnet_b4.pkl
IMAGE_FUSION_DEEP_SCALER_PATH=./models/weights/deep_scaler.pkl
IMAGE_FUSION_LAND_SCALER_PATH=./models/weights/land_scaler.pkl
IMAGE_FUSION_LANDMARK_PATH=./models/weights/shape_predictor_68_face_landmarks.dat

# Video model: ResNeXt101-32x8d trained on FaceForensics++ C23
VIDEO_MODEL_PATH=./models/weights/best_resnext101_deepfake.pth

# Audio model: CNN-LogMel trained on ASVspoof2019-LA
AUDIO_MODEL_PATH=./models/weights/best_audio_model.keras

# ── Inference thresholds ──────────────────────────────────────────────────────
# sigmoid output >= threshold → FAKE
IMAGE_FAKE_THRESHOLD=0.5
AUDIO_FAKE_THRESHOLD=0.5
# fake_frame_ratio >= threshold → FAKE (from notebook: fake_threshold=0.30)
VIDEO_FAKE_THRESHOLD=0.30
# number of frames to sample from each video
VIDEO_FRAME_COUNT=16

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./logs
